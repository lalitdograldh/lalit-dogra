{%- style -%}
  /* Mobile view: text → description → image sequence */
  @media screen and (max-width: 749px) {
    #Banner-{{ section.id }} {
      display: flex;
      flex-direction: column;
    }
    /* Move content (heading + text + button) above the image */
    #Banner-{{ section.id }} .banner__content {
      order: 1;
      position: relative;
      top: auto;
      left: auto;
      transform: none;
      width: 100%;
      padding: 2rem 1.5rem;
      background: transparent; /* or keep existing background */
    }
    /* Remove absolute positioning from the text box */
    #Banner-{{ section.id }} .banner__box {
      position: relative;
      top: auto;
      left: auto;
      transform: none;
      width: 100%;
      max-width: 100%;
      margin: 0 auto;
      padding: 20px;
      text-align: center;
      background: transparent; /* ensure no conflicting background */
    }
    /* Image appears below the content */
    #Banner-{{ section.id }} .banner__media {
      order: 2;
      /* position: relative; */
      width: 100%;
      margin-top: 0;
    }
    /* Adjust typography for mobile */
    #Banner-{{ section.id }} .banner__box .banner__heading {
      font-size: 36px;
      line-height: 1.2;
      text-align: center;
    }
    #Banner-{{ section.id }} .banner__box .banner__text {
      font-size: 16px;
      line-height: 1.4;
      text-align: center;
    }
    #Banner-{{ section.id }} .banner__box .banner__buttons {
